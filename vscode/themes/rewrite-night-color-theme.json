  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#a3a3a3"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.word",
        "storage",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#737373"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#fed7aa"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#fed7aa"
      }
    },
    {
      "scope": [
        "constant.language.null",
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#a3a3a3"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#f5f5f5"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.namespace",
        "support.class",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#f5f5f5"
      }
    },
    {
      "scope": [
        "variable",
        "meta.object-literal.key",
        "entity.name.variable",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f5f5f5"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#525252"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f5f5f5"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f5f5f5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#f5f5f5",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "type": "#a3a3a3",
    "type.declaration": "#f5f5f5",
    "type.defaultLibrary": "#a3a3a3",
    "enum": "#a3a3a3",
    "enum.declaration": "#f5f5f5",
    "class": "#a3a3a3",
    "class.declaration": "#f5f5f5",
    "interface": "#a3a3a3",
    "interface.declaration": "#f5f5f5",
    "namespace": "#f5f5f5",
    "typeParameter": "#e5e5e5",
    "function": "#f5f5f5",
    "method": "#f5f5f5",
    "parameter": "#f5f5f5",
    "property": "#f5f5f5",
    "variable": "#f5f5f5"
  }
}
