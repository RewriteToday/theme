  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8c7b69"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.word",
        "storage",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#8c7b69"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#c96a2d"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#c96a2d"
      }
    },
    {
      "scope": [
        "constant.language.null",
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#8f7e6d"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#3b3027"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.namespace",
        "support.class",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#3b3027"
      }
    },
    {
      "scope": [
        "variable",
        "meta.object-literal.key",
        "entity.name.variable",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#3b3027"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#b5a694"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#3b3027"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.bold"
      ],
      "settings": {
        "foreground": "#3b3027",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#3b3027",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "type": "#8f7e6d",
    "type.declaration": "#3b3027",
    "type.defaultLibrary": "#8f7e6d",
    "enum": "#8f7e6d",
    "enum.declaration": "#3b3027",
    "class": "#8f7e6d",
    "class.declaration": "#3b3027",
    "interface": "#8f7e6d",
    "interface.declaration": "#3b3027",
    "namespace": "#3b3027",
    "typeParameter": "#5f5144",
    "function": "#3b3027",
    "method": "#3b3027",
    "parameter": "#3b3027",
    "property": "#3b3027",
    "variable": "#3b3027"
  }
